# Google Sheets API key (read-only access to the Growth Pod sheet)
GOOGLE_SHEETS_API_KEY=your_google_sheets_api_key_here

# Google Drive API key (for reading linked Google Docs)
GOOGLE_DRIVE_API_KEY=your_google_drive_api_key_here

# Google OAuth2 (alternative to API key — needed for org-restricted sheets)
GOOGLE_CLIENT_ID=your_oauth_client_id
GOOGLE_CLIENT_SECRET=your_oauth_client_secret
GOOGLE_REFRESH_TOKEN=your_refresh_token

# AI key — use either Anthropic OR Gemini (Gemini has a free tier)
ANTHROPIC_API_KEY=sk-ant-your_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Slack bot (for Archie on Slack)
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret
